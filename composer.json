{
    "name": "verifiedit/laravel-notification-channel-clicksend",
    "description": "ClickSend notification channel for Laravel",
    "homepage": "https://github.com/verifiedit/clicksend",
    "license": "MIT",
    "authors": [
        {
            "name": "Verified International",
            "email": "developers@verified.com.au",
            "homepage": "https://www.verified.com.au",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.3",
        "ext-json": "*",
        "verifiedit/clicksend-sms": "^2.0",
        "illuminate/config": "^10 || ^11 || ^12 || ^13",
        "illuminate/events": "^10 || ^11 || ^12 || ^13",
        "illuminate/notifications": "^10 || ^11 || ^12 || ^13",
        "illuminate/queue": "^10 || ^11 || ^12 || ^13",
        "illuminate/support": "^10 || ^11 || ^12 || ^13"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.8",
        "laravel/pint": "^v1.0"
    },
    "autoload": {
        "psr-4": {
            "NotificationChannels\\ClickSend\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\NotificationChannels\\ClickSend\\": "tests"
        }
    },
    "scripts": {
        "pint": "./vendor/bin/pint",
        "pint:test": "@pint --test",
        "test": "phpunit tests --display-deprecations --display-notices",
        "test:coverage": "phpunit --configuration=phpunit.coverage.xml tests --coverage-text --coverage-clover=coverage.clover"
    },
    "minimum-stability": "dev",
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "NotificationChannels\\ClickSend\\ClickSendServiceProvider"
            ]
        }
    }
}
